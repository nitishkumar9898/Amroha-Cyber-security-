# =============================================================================
# CyberThreatForge — Root Environment Configuration
# WARNING: Never commit .env files. Copy this to .env and fill secrets.
# =============================================================================

# --- Application ---
APP_NAME=CyberThreatForge
NODE_ENV=development
APP_PORT=3000
API_PREFIX=/api/v1

# --- Security (must rotate in production) ---
JWT_SECRET=change-this-to-256bit-random-hex
JWT_REFRESH_SECRET=change-this-to-another-256bit-random-hex
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
SESSION_SECRET=change-this-to-secure-random-string
ENCRYPTION_KEY=change-this-to-256bit-aes-key
HASH_SALT_ROUNDS=12
CORS_ORIGIN=http://localhost:5173

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=cyberthreatforge
POSTGRES_USER=ctf_admin
POSTGRES_PASSWORD=change-this-strong-password
POSTGRES_SSL_ENABLED=false

# --- Neo4j (Graph Evidence) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-this-neo4j-password

# --- Vector Database (pgvector / Qdrant) ---
VECTOR_DB_PROVIDER=pgvector
VECTOR_DB_URL=postgresql://ctf_admin:change-this-strong-password@localhost:5432/cyberthreatforge
VECTOR_DIMENSION=1536

# --- Redis (Session / Cache / Rate-Limit) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- MinIO / S3 (Evidence Blob Storage) ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=ctf_minio
S3_SECRET_KEY=change-this-minio-key
S3_BUCKET_EVIDENCE=ctf-evidence
S3_BUCKET_LOGS=ctf-logs
S3_USE_SSL=false

# --- AI / LLM ---
LLM_PROVIDER=openai
LLM_API_KEY=sk-change-this
LLM_MODEL=gpt-4-turbo
EMBEDDING_MODEL=text-embedding-3-small

# --- Dark Web Monitoring ---
TOR_PROXY_HOST=localhost
TOR_PROXY_PORT=9050
DARKWEB_CRAWL_INTERVAL_MS=3600000

# --- Multi-Factor Authentication ---
MFA_ISSUER=CyberThreatForge
OTP_ALGORITHM=SHA1
OTP_DIGITS=6
OTP_PERIOD=30

# --- Audit (Immutable Logging) ---
AUDIT_LOG_PROVIDER=postgres
AUDIT_LOG_TABLE=audit_log_immutable
AUDIT_HMAC_KEY=change-this-hmac-key-for-chain-integrity

# --- DPDP Act Compliance (India) ---
DATA_RETENTION_DAYS=365
ANONYMIZE_IP=true
PII_MASKING_ENABLED=true
CONSENT_REQUIRED=true

# --- Monitoring ---
SENTRY_DSN=
METRICS_ENABLED=true
LOG_LEVEL=debug
